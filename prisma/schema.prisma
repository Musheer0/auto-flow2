// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  picture     String?
  accounts    account[]
  sessions    session[]
  workflows   workflow[]
  credentials credential[]
  ai_usage    ai_usage?
  messages  message[]
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
}

enum account_type {
  GOOGLE
}

model account {
  id            String   @id @default(cuid())
  user_id       String
  user          user     @relation(references: [id], fields: [user_id], onDelete: Cascade)
  refresh_token String
  expires_at    DateTime
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  scope         String
}

model session {
  id      String @id @default(cuid())
  user_id String
  user    user   @relation(references: [id], fields: [user_id], onDelete: Cascade)

  ip         String?
  ua         String
  expires_at DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

enum NodeType {
  MANUAL_TRIGGER
  WEBHOOK
  HTTP_REQUEST
  SEND_TELEGRAM_MESSAGE
  SEND_EMAIL
  SEND_DISCORD_MESSAGE
}
enum NodeAction {
  EXECUTOR
  TRIGGER
}
model workflow {
  id         String   @id @default(cuid())
  user_id    String
  user       user     @relation(references: [id], fields: [user_id], onDelete: Cascade)
  data       String   @default("{}")
  name       String   @default("untitled workflow")
  
  messages message[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model credential {
  id         String   @id @default(cuid())
  user_id    String
  user       user     @relation(references: [id], fields: [user_id], onDelete: Cascade)
  data       String
  type       NodeType
  name       String   @default("untitled workflow")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([type, user_id])
}

model ai_usage {
  id         String   @id @default(cuid())
  user_id    String @unique
  user       user     @relation(references: [id], fields: [user_id], onDelete: Cascade)
  credits_alloted   Int  @default(10000)
  credits_used   Int @default(0)   
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

enum MessageType {
  USER
  AI
  WORKFLOW
}
model message {
  id      String   @id @default(cuid())
  user_id   String 
  user      user     @relation(references: [id], fields: [user_id], onDelete: Cascade)

  workflow_id String

  workflow workflow  @relation(references: [id], fields: [workflow_id], onDelete: Cascade)
  type      MessageType    @default(USER)
  content   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  credits_used   Int @default(0)   

}